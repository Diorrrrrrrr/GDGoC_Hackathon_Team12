# Direct Postgres connection (Supabase: Settings -> Database -> Connection string).
# We use Supabase only as a managed Postgres host. No Supabase Auth, no anon key, no JWT secret.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Secret used to sign/verify our own JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_JWT_SECRET=replace-me-with-a-long-random-string

# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:3000
